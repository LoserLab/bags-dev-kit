      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "Trading bot poll loop catches and logs errors without recovery or back-off",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "templates/trading-bot/src/index.ts"
        ],
        "evidence": [
          "Line 37: 'catch (error) { console.error(\"Poll error:\", error); }' silently swallows the error and the next poll fires 10 seconds later regardless",
          "No back-off, no error counter, no circuit breaker. Repeated API failures (rate limit, auth expiry) will spam the console indefinitely"
        ],
